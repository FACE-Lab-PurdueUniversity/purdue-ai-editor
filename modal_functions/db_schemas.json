          "exclusiveMinimum": true,
          "maximum": 9007199254740991
        },
        "current_conversation_id": {
          "nullable": true,
          "type": "integer",
          "exclusiveMinimum": true,
          "maximum": 9007199254740991
        },
        "name": {
